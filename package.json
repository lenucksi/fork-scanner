{
  "name": "@lenucksi/fork-scanner",
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lenucksi/fork-scanner.git"
  },
  "type": "module",
  "bin": {
    "fork-scan": "./dist/index.js"
  },
  "files": ["dist", "templates", "README.md"],
  "scripts": {
    "build": "bun run update-vendors && bun build src/index.ts --outdir dist --target bun",
    "update-vendors": "bun scripts/update-vendors.ts",
    "prepublish": "bun run build",
    "typecheck": "bunx tsc --noEmit",
    "test:e2e": "npx playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.7.0"
  }
}
